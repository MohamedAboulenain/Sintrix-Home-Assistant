# Sintrix per-house connection secrets — copy to `.env` and fill in.
# `.env` is gitignored. NEVER commit real tokens.
#
# These values must be present in the ENVIRONMENT when you launch Claude Code, because
# `.mcp.json` expands ${HOMEASSISTANT_URL} / ${HOMEASSISTANT_TOKEN}. Variable names match what
# ha-mcp itself requires. Set them in your shell before launching, or use a .env loader.
# Windows PowerShell:  $env:HOMEASSISTANT_URL="..."; $env:HOMEASSISTANT_TOKEN="..."
#
# ACCESS POLICY (ATM principles): use a DEDICATED, LEAST-PRIVILEGE long-lived access token
# for this house. REVOKE it at project handover.

# Home Assistant URL for THIS house (remote or on-site both work with the local stdio server).
#   Remote:  https://your-house.ui.nabu.casa
#   On-site: http://homeassistant.local:8123
HOMEASSISTANT_URL=http://homeassistant.local:8123

# Dedicated long-lived access token (HA → profile → Security → Long-lived access tokens).
HOMEASSISTANT_TOKEN=replace-with-least-privilege-token

# --- Only if you instead use the ha-mcp ADD-ON (remote HTTP) ---
# Set .mcp.json's server to { "type": "http", "url": "<this>" } and enable feature flags in the
# add-on panel. The URL is printed in the add-on logs.
# HA_MCP_ADDON_URL=https://xxxxx.ui.nabu.casa/api/webhook/mcp_xxxxxxxx
